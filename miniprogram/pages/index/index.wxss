.container {
  padding: 24rpx 32rpx 48rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-top: 8rpx;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #161b22;
  border: 1rpx solid #30363d;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.arrow {
  color: #8b949e;
  font-size: 20rpx;
}

.btn-run {
  background: #58a6ff !important;
  color: #fff !important;
  font-weight: 600;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.hero-card {
  background: linear-gradient(135deg, #161b22, #1c2333);
  border: 1rpx solid #30363d;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.symbol-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.symbol-name {
  font-size: 36rpx;
  font-weight: 700;
}

.symbol-code {
  margin-left: 12rpx;
  color: #8b949e;
  font-size: 26rpx;
}

.price {
  font-size: 48rpx;
  font-weight: 700;
  color: #58a6ff;
}

.prob-bar {
  display: flex;
  height: 48rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.prob-seg {
  min-width: 0;
}

.prob-seg.up { background: #3fb950; }
.prob-seg.side { background: #d29922; }
.prob-seg.down { background: #f85149; }

.prob-legend {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #8b949e;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card {
  background: #161b22;
  border: 1rpx solid #30363d;
  border-radius: 16rpx;
  padding: 24rpx;
}

.card-title {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 12rpx;
}

.decision-badge {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.decision-label {
  font-size: 24rpx;
  color: #8b949e;
}

.metric {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.position-bar {
  height: 8rpx;
  background: #30363d;
  border-radius: 4rpx;
  overflow: hidden;
}

.position-fill {
  height: 100%;
  background: #58a6ff;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 24rpx;
  border-bottom: 1rpx solid #30363d;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  color: #8b949e;
}

.note {
  font-size: 24rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #30363d;
}

.note:last-child {
  border-bottom: none;
}

.report-card {
  margin-bottom: 24rpx;
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.btn-copy {
  background: transparent !important;
  color: #8b949e !important;
  border: 1rpx solid #30363d !important;
  font-size: 22rpx !important;
  margin: 0 !important;
  padding: 0 16rpx !important;
  line-height: 48rpx !important;
}

.report {
  display: block;
  background: #0d1117;
  border: 1rpx solid #30363d;
  border-radius: 8rpx;
  padding: 20rpx;
  font-family: Menlo, monospace;
  font-size: 22rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  color: #8b949e;
  padding: 16rpx 0;
}

.v8-section {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.cond-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #30363d;
}

.cond-item:last-child {
  border-bottom: none;
}

.cond-type {
  display: block;
  font-weight: 700;
  font-size: 26rpx;
  margin-bottom: 6rpx;
}

.cond-detail {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
}

.cond-path {
  display: block;
  font-size: 22rpx;
  color: #58a6ff;
  margin-top: 4rpx;
}
