{
  "manifest_version": 3,
  "name": "A股反收割系统 v7",
  "version": "7.0.0",
  "description": "AI交易决策系统 — 盘口+资金+情绪 → 走势概率预测",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "A股反收割系统 v7",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://*.eastmoney.com/*", "https://*.10jqka.com.cn/*"],
  "content_scripts": [
    {
      "matches": ["https://*.eastmoney.com/*", "https://*.10jqka.com.cn/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
